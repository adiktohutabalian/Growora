generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Users ────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  fullName       String
  username       String   @unique
  email          String   @unique
  passwordHash   String
  avatar         String?
  bio            String?
  location       String?
  availability   String   @default("[]") // JSON array: ["morning", "afternoon", "evening", "weekend"]
  growthLevel    Int      @default(1)
  completedSwaps Int      @default(0)
  rating         Float    @default(0)
  reviewCount    Int      @default(0)
  isPremium      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  skillsTeach     UserSkill[]
  skillsLearn     UserSkillDesire[]
  portfolio       PortfolioItem[]
  reviewsGiven    Review[]          @relation("ReviewAuthor")
  reviewsReceived Review[]          @relation("ReviewTarget")
  swapRequests    SwapRequest[]     @relation("SwapRequester")
  swapReceived    SwapRequest[]     @relation("SwapReceiver")
  messages        Message[]
  notifications   Notification[]
  sessionsAsA     ScheduledSession[]       @relation("SessionUserA")
  sessionsAsB     ScheduledSession[]       @relation("SessionUserB")
  conversations   ConversationParticipant[]

  @@map("users")
}

// ── Skills ───────────────────────────────────────────────────────────────

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String   // programming, design, language, creative, business, music, fitness, cooking
  description String
  icon        String
  mentorCount Int      @default(0)
  createdAt   DateTime @default(now())

  usersTeach UserSkill[]
  usersLearn UserSkillDesire[]

  @@map("skills")
}

// ── User Skills (teach) ──────────────────────────────────────────────────

model UserSkill {
  id          String  @id @default(cuid())
  userId      String
  skillId     String
  level       String // beginner, intermediate, advanced, expert
  description String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@map("user_skills")
}

// ── User Skill Desires (learn) ───────────────────────────────────────────

model UserSkillDesire {
  id      String @id @default(cuid())
  userId  String
  skillId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@map("user_skill_desires")
}

// ── Swap Requests ────────────────────────────────────────────────────────

model SwapRequest {
  id           String   @id @default(cuid())
  requesterId  String
  receiverId   String
  skillOffered String
  skillWanted  String
  message      String
  status       String   @default("pending") // pending, accepted, rejected, completed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  requester User @relation("SwapRequester", fields: [requesterId], references: [id])
  receiver  User @relation("SwapReceiver", fields: [receiverId], references: [id])

  @@map("swap_requests")
}

// ── Reviews ──────────────────────────────────────────────────────────────

model Review {
  id              String   @id @default(cuid())
  authorId        String
  targetId        String
  swapRequestId   String?
  rating          Int
  communication   Int
  teachingQuality Int
  reliability     Int
  comment         String
  createdAt       DateTime @default(now())

  author User @relation("ReviewAuthor", fields: [authorId], references: [id])
  target User @relation("ReviewTarget", fields: [targetId], references: [id])

  @@map("reviews")
}

// ── Conversations ────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages     Message[]
  participants ConversationParticipant[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  userId         String
  conversationId String
  lastReadAt     DateTime?

  user         User         @relation(fields: [userId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@map("conversation_participants")
}

// ── Messages ─────────────────────────────────────────────────────────────

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           String   @default("text") // text, file, system
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@map("messages")
}

// ── Scheduled Sessions ───────────────────────────────────────────────────

model ScheduledSession {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  skill     String
  date      DateTime
  time      String
  mode      String // online, in_person
  notes     String?
  status    String   @default("pending") // pending, confirmed, completed, cancelled
  createdAt DateTime @default(now())

  userA User @relation("SessionUserA", fields: [userAId], references: [id])
  userB User @relation("SessionUserB", fields: [userBId], references: [id])

  @@map("scheduled_sessions")
}

// ── Notifications ────────────────────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String // swap_request, swap_accepted, swap_completed, message, review, match, system
  title       String
  description String
  read        Boolean  @default(false)
  link        String?
  avatar      String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ── Portfolio Items ──────────────────────────────────────────────────────

model PortfolioItem {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  type        String // image, video, link, certificate
  url         String
  thumbnail   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portfolio_items")
}
